@{

    Layout = null;

}

<!DOCTYPE html>

<html lang="es">

<head>

    <meta charset="UTF-8" />

    <title>Ofertas — Repartidor</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>

        body {
        font-family: 'Inter', sans-serif;
        background-color: #FBF6EC;
        color: #14120F;
        }



        .font-archivo {
        font-family: 'Archivo Black', sans-serif;
        }

    </style>

</head>

<body class="h-screen flex overflow-hidden">



    <aside class="w-64 bg-[#14120F] text-[#FBF6EC] p-6 flex flex-col justify-between shrink-0">

        <div>

            <div class="font-mono text-sm tracking-wider mb-8 font-bold text-[#FF4D2E]">DELIVERY · REPARTIDOR</div>

            <nav class="flex flex-col gap-1 text-sm font-medium">

                <a href="/Delivery/Start" class="px-4 py-3 rounded-xl bg-[#FF4D2E] text-white font-semibold">📦 Ofertas y entrega</a>

                <a href="/Delivery/Earnings" class="px-4 py-3 rounded-xl text-[#c8c1b0] hover:bg-neutral-900 hover:text-white">💰 Ganancias</a>

                <a href="/Delivery/Reviews" class="px-4 py-3 rounded-xl text-[#c8c1b0] hover:bg-neutral-900 hover:text-white">⭐ Reseñas</a>

                <a href="/Delivery/Reports" class="px-4 py-3 rounded-xl text-[#c8c1b0] hover:bg-neutral-900 hover:text-white">🚨 Mis Reportes</a>

            </nav>

        </div>

        <div>

            <div class="text-xs text-[#8A8578] font-mono mb-2" id="deliveryLabel">Cargando...</div>

            <button onclick="logout()" class="w-full bg-neutral-900 py-3 rounded-xl text-xs font-bold text-neutral-400 hover:bg-red-600 hover:text-white">⚠️ CERRAR SESIÓN</button>

        </div>

    </aside>



    <main class="flex-1 overflow-y-auto p-8 max-w-4xl mx-auto w-full">

        <!-- PEDIDO ACTIVO -->

        <div id="activeOrderSection" class="hidden mb-8">

            <h1 class="font-archivo text-2xl mb-4">🚴 Tu entrega activa</h1>

            <div id="activeOrderCard"></div>

        </div>



        <!-- OFERTAS DISPONIBLES -->

        <div id="offersSection">

            <h1 class="font-archivo text-2xl mb-4">Ofertas disponibles</h1>

            <div id="offersList" class="space-y-4">

                <p class="text-sm text-[#8A8578]">Buscando pedidos disponibles...</p>

            </div>

        </div>

    </main>



    <!-- VISTA MODAL PARA VER EL TELÉFONO DE CONTACTO Y EL BOTÓN DE COPIAR -->

    <div id="phoneModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">

        <div class="bg-white border-2 border-[#14120F] rounded-2xl p-6 max-w-xs w-full shadow-[6px_6px_0px_0px_rgba(20,18,15,1)]">

            <h3 class="font-archivo text-base mb-2 text-black" id="phoneModalTitle">Contacto</h3>

            <p class="text-xs text-[#8A8578] mb-3">Copia el número de teléfono para realizar la llamada:</p>



            <div class="flex items-center justify-between bg-[#FBF6EC] border-2 border-[#E4DAC4] rounded-xl px-4 py-3 mb-4">

                <span id="phoneModalNumber" class="font-mono text-base font-bold text-black tracking-wide">--------</span>

                <button onclick="copyPhoneNumber()" class="p-1 hover:bg-[#E4DAC4] rounded-lg transition-all" title="Copiar número">

                    <svg class="w-5 h-5 text-neutral-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">

                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />

                    </svg>

                </button>

            </div>



            <button onclick="closePhoneModal()" class="w-full bg-[#14120F] text-white py-2.5 rounded-xl text-xs font-bold font-archivo">CERRAR</button>

        </div>

    </div>



    <script>

        const DELIVERY_ID = localStorage.getItem('userId');

        const DELIVERY_NAME = localStorage.getItem('userName');

        const API_BASE = "https://localhost:7042";



        if (!DELIVERY_ID || localStorage.getItem('userRole') !== 'Delivery') {

        window.location.href = '/Auth/Login';

        } else {

        document.getElementById('deliveryLabel').innerText = DELIVERY_NAME;

        }



        function logout() {

        localStorage.clear();

        window.location.href = '/Auth/Login';

        }



        function itemsSummary(order) {

        if (!order.detailOrders || order.detailOrders.length === 0) return 'Sin detalle de productos';

        return order.detailOrders.map(d => `${d.quantity}x ${d.product ? d.product.name : 'Producto'}`).join(', ');

        }



        function restaurantOf(order) {

        const first = order.detailOrders && order.detailOrders[0];

        return first && first.product && first.product.restaurant ? first.product.restaurant.commercialName : 'Restaurante';

        }



        function restaurantPhoneOf(order) {

        const first = order.detailOrders && order.detailOrders[0];

        return first && first.product && first.product.restaurant ? first.product.restaurant.phone : '';

        }



        async function loadActiveOrder() {

        try {

        const res = await fetch(`${API_BASE}/api/Orders/by-status/${encodeURIComponent('En camino')}`);

        const orders = await res.json();

        const mine = (orders || []).find(o => o.deliveryId == DELIVERY_ID);



        const section = document.getElementById('activeOrderSection');

        const offersSection = document.getElementById('offersSection');



        if (!mine) {

        section.classList.add('hidden');

        offersSection.classList.remove('hidden');

        loadOffers();

        return;

        }



        offersSection.classList.add('hidden');

        section.classList.remove('hidden');



        const clientAddress = mine.client ? mine.client.mainAddress : 'Dirección no disponible';

        const clientPhone = mine.client ? mine.client.phone : '';

        const restPhone = restaurantPhoneOf(mine);



        document.getElementById('activeOrderCard').innerHTML = `

        <div class="bg-white border-2 border-[#14120F] rounded-2xl p-6 shadow-[4px_4px_0px_0px_rgba(20,18,15,1)]">

        <div class="flex justify-between items-start mb-3">

        <div>

        <span class="font-mono text-xs text-[#FF4D2E] font-bold">#ORD-${mine.id}</span>

        <h3 class="font-archivo text-lg mt-1">${restaurantOf(mine)}</h3>

        </div>

        <span class="text-xs font-mono bg-[#E8A33D]/20 text-[#E8A33D] font-bold px-3 py-1 rounded-full">EN RUTA</span>

        </div>

        <p class="text-sm text-neutral-600 mb-1"><b>Cliente:</b> ${mine.client ? mine.client.name : 'Cliente'}</p>

        <p class="text-sm text-neutral-600 mb-1"><b>Dirección:</b> ${clientAddress}</p>

        <p class="text-sm text-neutral-600 mb-4"><b>Productos:</b> ${itemsSummary(mine)}</p>



        <!-- FILA DE LOS 3 BOTONES ALINEADOS (MAPA LOCAL + BOTONES LLAMADAS) -->

        <div class="flex flex-wrap gap-2">

        <button onclick="window.location.href='/Delivery/Tracking?orderId=${mine.id}&pago=${encodeURIComponent(mine.payMethodType || '')}'" class="bg-[#6B8F71] text-white px-5 py-2.5 rounded-xl text-xs font-bold hover:bg-[#14120F]">🗺️ VER MAPA Y SEGUIMIENTO →</button>

        <button onclick="openPhoneModal('Cliente', '${clientPhone}')" class="bg-white border-2 border-[#14120F] px-4 py-2.5 rounded-xl text-xs font-bold hover:bg-neutral-100">📞 Llamar al cliente</button>

        <button onclick="openPhoneModal('Restaurante', '${restPhone}')" class="bg-white border-2 border-[#14120F] px-4 py-2.5 rounded-xl text-xs font-bold hover:bg-neutral-100">📞 Llamar al restaurante</button>

        </div>

        </div>`;

        } catch (err) {

        console.error(err);

        }

        }



        async function loadOffers() {

        const list = document.getElementById('offersList');

        try {

        const [resPend, resPrep] = await Promise.all([

        fetch(`${API_BASE}/api/Orders/by-status/Pendiente`),

        fetch(`${API_BASE}/api/Orders/by-status/${encodeURIComponent('En preparación')}`)

        ]);

        const offers = [...(await resPend.json() || []), ...(await resPrep.json() || [])];



        list.innerHTML = '';

        if (offers.length === 0) {

        list.innerHTML = `<p class="text-sm text-[#8A8578]">No hay pedidos disponibles por ahora.</p>`;

        return;

        }



        offers.forEach(o => {

        // 👉 CORRECCIÓN CLAVE: Creamos la URL usando la latitud y longitud exactas donde el cliente fijó la entrega en el mapa del Cart

        const mapsUrl = o.latCliente && o.lngCliente

        ? `https://www.google.com/maps/search/?api=1&query=${o.latCliente},${o.lngCliente}`

        : `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent("Ibarra, Ecuador")}`;



        list.innerHTML += `

        <div class="bg-white border-2 border-[#14120F] rounded-2xl p-5 flex justify-between items-center gap-4 shadow-[3px_3px_0px_0px_rgba(20,18,15,1)]">

        <div>

        <span class="font-mono text-xs text-[#FF4D2E] font-bold">#ORD-${o.id}</span>

        <h4 class="font-archivo text-base mt-1">${restaurantOf(o)}</h4>



        <!-- El botón negro Navegar directo sin ninguna etiqueta de texto amontonada -->

        <div class="mt-3">

        <a href="${mapsUrl}" target="_blank" class="inline-flex bg-[#14120F] text-white px-4 py-2 rounded-xl text-xs font-bold hover:bg-[#FF4D2E] transition-all font-archivo tracking-wide">🧭 Navegar (Google Maps)</a>

        </div>

        </div>

        <button onclick="acceptOrder(${o.id})" class="bg-[#FF4D2E] text-white px-4 py-2.5 rounded-xl text-xs font-bold hover:bg-[#14120F]">Aceptar</button>

        </div>`;

        });

        } catch (err) {

        console.error(err);

        }

        }



        async function acceptOrder(orderId) {

        try {

        const res = await fetch(`${API_BASE}/api/Orders/${orderId}/assign-delivery/${DELIVERY_ID}`, { method: 'POST' });

        if (res.ok) {

        

        await loadActiveOrder();

        } else {

        alert("No se pudo aceptar el pedido.");

        }

        } catch (err) {

        alert("Error de conexión.");

        }

        }



        function openPhoneModal(tipo, number) {

        document.getElementById('phoneModalTitle').innerText = `Contacto del ${tipo}`;

        document.getElementById('phoneModalNumber').innerText = number || 'No registrado';

        document.getElementById('phoneModal').classList.remove('hidden');

        }



        function closePhoneModal() {

        document.getElementById('phoneModal').classList.add('hidden');

        }



        function copyPhoneNumber() {

        const num = document.getElementById('phoneModalNumber').innerText;

        if (num && num !== 'No registrado') {

        navigator.clipboard.writeText(num);

        alert("¡Número copiado correctamente!");

        }

        }



        loadActiveOrder();

        setInterval(loadActiveOrder, 15000);

    </script>

</body>

</html>