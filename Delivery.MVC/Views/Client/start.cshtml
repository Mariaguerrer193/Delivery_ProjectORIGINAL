@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inicio — Cliente</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/client-start.css" />
</head>

<body class="flex min-h-screen">

    <aside class="w-[240px] bg-[#14120F] text-[#FBF6EC] p-6 flex flex-col justify-between sticky top-0 h-screen shrink-0">
        <div>
            <div class="font-mono text-sm tracking-[0.12em] flex items-center gap-2 mb-8 px-2 font-bold">
                <span class="inline-block w-2 h-2 rounded-full bg-[#FF4D2E] shadow-[0_0_0_4px_rgba(255,77,46,0.2)]"></span>
                DELIVERY
            </div>

            <nav class="flex flex-col gap-1">
                <a href="/Client/Start" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-[#c8c1b0] hover:bg-neutral-900 hover:text-white transition-all"><span>🏠</span> Inicio</a>
                <a href="/Client/Search" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-[#c8c1b0] hover:bg-neutral-900 hover:text-white transition-all"><span>🔍</span> Buscar Platos</a>
                <a href="/Client/Cart" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-[#c8c1b0] hover:bg-neutral-900 hover:text-white transition-all"><span>🛒</span> Mi Carrito</a>
                <a href="/Client/Orders" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-[#c8c1b0] hover:bg-neutral-900 hover:text-white transition-all"><span>🧾</span> Mis Pedidos</a>
                <a href="/Client/Reviews" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-[#c8c1b0] hover:bg-neutral-900 hover:text-white transition-all"><span>⭐</span> Reseñas</a>
                <a href="/Client/Coupons" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-[#c8c1b0] hover:bg-neutral-900 hover:text-white transition-all"><span>🏷️</span> Cupones</a>

            </nav>
        </div>

        <div class="border-t border-neutral-800 pt-4 flex flex-col gap-3">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-[#E8A33D] flex items-center justify-center font-bold text-[#14120F] text-sm font-archivo" id="avatarCircle">
                    U
                </div>
                <div class="text-xs">
                    <b class="block text-sm font-semibold text-white" id="clientName">Usuario</b>
                    <span class="text-[#8A8578] font-mono">CLIENTE</span>
                </div>
            </div>
            <button onclick="logout()" class="w-full text-center text-xs bg-neutral-900 hover:bg-red-600 hover:text-white font-bold py-2 rounded-lg transition-all font-mono">
                CERRAR SESIÓN
            </button>
        </div>
    </aside>

    <main class="flex-1 p-10 max-w-[1200px] mx-auto overflow-y-auto">

        <div class="flex justify-between items-start mb-6 gap-6">
            <div>
                <h1 class="font-archivo text-3xl tracking-tight" id="greetingHeader">¡Hola! 👋</h1>
                <p class="text-[#8A8578] text-sm mt-1">¿Qué se te antoja comer hoy?</p>
            </div>
            <div class="flex items-center gap-2 bg-white border-2 border-[#E4DAC4] rounded-xl px-4 py-3 w-[340px] shadow-[2px_2px_0px_0px_rgba(20,18,15,1)]">
                <span>🔍</span>
                <input type="text" id="searchInput" placeholder="Buscar restaurantes o platos..." class="border-none outline-none text-sm w-full font-medium bg-transparent placeholder-neutral-400" />
            </div>
        </div>

        <div class="bg-[#14120F] text-[#FBF6EC] rounded-2xl p-6 flex justify-between items-center gap-6 mb-8 relative overflow-hidden shadow-[4px_4px_0px_0px_rgba(255,77,46,0.2)]">
            <div class="relative z-10">
                <div class="font-mono text-[11px] tracking-wider text-[#E8A33D] flex items-center gap-2">
                    <div class="blip"></div> PEDIDO ACTIVO · EN PREPARACIÓN
                </div>
                <h2 class="font-archivo text-xl mt-2">Tu comida se está cocinando</h2>
                <p class="text-neutral-400 text-xs mt-1">El sistema notificará a los repartidores disponibles en cuanto esté listo.</p>
            </div>
            <div class="ao-route relative w-[180px] h-[60px] hidden sm:block">
                <svg viewBox="0 0 180 60">
                    <path d="M5 50 C 50 50, 50 10, 90 10 S 150 50, 175 20"></path>
                    <path class="p" d="M5 50 C 50 50, 50 10, 90 10 S 150 50, 175 20"></path>
                </svg>
            </div>
            <button onclick="window.location.href='/Client/Tracking?orderId=' + (localStorage.getItem('activeOrderId') || 1)" class="bg-[#FF4D2E] text-white hover:bg-white hover:text-[#14120F] border-none font-bold py-3 px-5 rounded-xl text-xs tracking-wide transition-all font-archivo shrink-0 relative z-10">
                VER EN MAPA →
            </button>
        </div>

        <div class="flex gap-2 flex-wrap mb-2" id="categoryFilterBar">
            <button data-category="" class="category-chip bg-[#14120F] text-[#FBF6EC] border-2 border-[#14120F] px-4 py-2 rounded-full text-xs font-bold font-mono transition-all">Todo</button>
        </div>
        <p class="text-[11px] text-[#8A8578] font-mono mb-8">
            ¿Buscas otra categoría? Filtra por precio y categoría completas en
            <a href="/Client/Search" class="text-[#FF4D2E] font-bold hover:underline">Buscar Platos →</a>
        </p>

        <div class="flex justify-between items-baseline mb-4">
            <h3 class="font-archivo text-lg tracking-tight">Restaurantes Disponibles</h3>
            <a href="#" class="text-xs font-bold text-[#FF4D2E] hover:underline">Ver todos →</a>
        </div>

        <div id="restaurantsGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        </div>
    </main>

    <script>
        const userId = localStorage.getItem('userId');
        const userName = localStorage.getItem('userName');
        const userRole = localStorage.getItem('userRole');

        if (!userId || userRole !== 'Client') {
        window.location.href = '/Auth/Login';
        } else {
        document.getElementById('clientName').innerText = userName;
        document.getElementById('greetingHeader').innerText = `¡Hola, ${userName.split(' ')[0]} 👋!`;
        document.getElementById('avatarCircle').innerText = userName.substring(0, 2).toUpperCase();
        }

        function logout() {
        localStorage.clear();
        window.location.href = '/Auth/Login';
        }

        let allRestaurants = [];
        let activeCategory = '';

        async function loadRestaurants() {
        try {
        const response = await fetch('https://localhost:7042/api/Restaurants');
        if (response.ok) {
        allRestaurants = await response.json();
        buildCategoryChips();
        renderRestaurants(allRestaurants);
        } else {
        document.getElementById('restaurantsGrid').innerHTML = `<p class="text-xs text-[#8A8578] col-span-full">No se pudieron cargar los negocios.</p>`;
        }
        } catch (error) {
        console.error(error);
        document.getElementById('restaurantsGrid').innerHTML = `<p class="text-xs text-[#8A8578] col-span-full">Error al conectar con la API.</p>`;
        }
        }

        function buildCategoryChips() {
        const bar = document.getElementById('categoryFilterBar');

        // Categorías reales que existen entre los restaurantes cargados
        const categories = [...new Set(allRestaurants.map(r => r.category).filter(c => c && c.trim() !== ''))].sort();

        categories.forEach(cat => {
        const btn = document.createElement('button');
        btn.dataset.category = cat;
        btn.className = 'category-chip bg-white text-[#14120F] border-2 border-[#E4DAC4] hover:border-[#14120F] px-4 py-2 rounded-full text-xs font-bold font-mono transition-all';
        btn.innerText = cat;
        bar.appendChild(btn);
        });

        attachCategoryEvents();
        }

        function attachCategoryEvents() {
        document.querySelectorAll('.category-chip').forEach(btn => {
        btn.addEventListener('click', () => {
        activeCategory = btn.dataset.category;

        document.querySelectorAll('.category-chip').forEach(b => {
        b.classList.remove('bg-[#14120F]', 'text-[#FBF6EC]', 'border-[#14120F]');
        b.classList.add('bg-white', 'text-[#14120F]', 'border-[#E4DAC4]');
        });

        btn.classList.remove('bg-white', 'border-[#E4DAC4]');
        btn.classList.add('bg-[#14120F]', 'text-[#FBF6EC]', 'border-[#14120F]');

        applyFilters();
        });
        });
        }

        function applyFilters() {
        const term = document.getElementById('searchInput').value.trim().toLowerCase();

        const filtered = allRestaurants.filter(r => {
        const name = (r.commercialName || r.name || '').toLowerCase();
        const category = (r.category || '').toLowerCase();

        const matchesText = !term || name.includes(term) || category.includes(term);
        const matchesCategory = !activeCategory || category === activeCategory.toLowerCase();

        return matchesText && matchesCategory;
        });

        renderRestaurants(filtered);
        }

        document.getElementById('searchInput').addEventListener('input', applyFilters);

        function renderRestaurants(restaurants) {
        const grid = document.getElementById('restaurantsGrid');
        grid.innerHTML = '';

        const foodImages = [
        'https://images.unsplash.com/photo-1568901346375-23c9450c58cd?auto=format&fit=crop&w=500&q=80',
        'https://images.unsplash.com/photo-1513104890138-7c749659a591?auto=format&fit=crop&w=500&q=80',
        'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?auto=format&fit=crop&w=500&q=80',
        'https://images.unsplash.com/photo-1551024601-bec78aea704b?auto=format&fit=crop&w=500&q=80',
        'https://images.unsplash.com/photo-1565299585323-38d6b0865b47?auto=format&fit=crop&w=500&q=80'
        ];

        if (restaurants.length === 0) {
        grid.innerHTML = `<p class="text-sm text-[#8A8578] font-mono col-span-full">No se encontraron restaurantes que coincidan con tu búsqueda.</p>`;
        return;
        }

        restaurants.forEach((r, index) => {
        const imgUrl = r.photoUrl || foodImages[index % foodImages.length];

        grid.innerHTML += `
        <div onclick="window.location.href='/Client/Menu?restaurantId=${r.id}'" class="bg-white border-2 border-[#E4DAC4] rounded-2xl overflow-hidden hover:-translate-y-1 transition-all duration-150 shadow-[4px_4px_0px_0px_rgba(20,18,15,1)] cursor-pointer">
        <div class="h-40 bg-cover bg-center relative" style="background-image: url('${imgUrl}')">
        <span class="absolute top-3 left-3 bg-[#14120F]/80 text-[#FBF6EC] font-mono text-[10px] font-bold px-2.5 py-1 rounded-full tracking-wider">
        ⏱️ 20-30 MIN
        </span>
        </div>
        <div class="p-4 bg-white">
        <h4 class="font-archivo text-base text-[#14120F] truncate">${r.commercialName || r.name}</h4>
        <div class="flex justify-between items-center mt-3 pt-3 border-t border-dashed border-[#E4DAC4] text-xs font-mono text-[#8A8578]">
        <span class="font-bold text-[#14120F] bg-[#FBF6EC] px-2 py-0.5 rounded border border-[#E4DAC4]">★ 4.8</span>
        <span>${r.category || 'Varios'}</span>
        </div>
        </div>
        </div>
        `;
        });
        }

        loadRestaurants();
    </script>
</body>
</html>
