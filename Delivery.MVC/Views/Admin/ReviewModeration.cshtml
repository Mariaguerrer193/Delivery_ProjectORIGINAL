@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <title>Moderación de Reseñas — GoDelivery</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
        font-family: 'Inter', sans-serif;
        background-color: #FBF6EC;
        color: #14120F;
        }

        .font-archivo {
        font-family: 'Archivo Black', sans-serif;
        }
    </style>
</head>
<body class="h-screen flex overflow-hidden">

    <aside class="w-64 bg-[#14120F] text-[#FBF6EC] p-6 flex flex-col justify-between shrink-0">
        <div>
            <div class="font-mono text-sm tracking-wider mb-8 font-bold text-[#FF4D2E]">DELIVERY · ADMIN</div>
            <div class="flex flex-col gap-1 text-sm font-medium">
                <button onclick="showTab('dashboard')" class="tab-btn active px-4 py-3 rounded-xl text-left" data-tab="dashboard">📊 Dashboard Global</button>
                <button onclick="showTab('cuentas')" class="tab-btn px-4 py-3 rounded-xl text-left text-[#c8c1b0] hover:bg-neutral-900" data-tab="cuentas">👤 Contratar Personal</button>
                <a href="/Admin/CouponManagement" class="px-4 py-3 rounded-xl text-left text-[#c8c1b0] hover:bg-neutral-900 block">🏷️ Cupones</a>
                <a href="/Admin/ReviewModeration" class="px-4 py-3 rounded-xl text-left text-[#c8c1b0] hover:bg-neutral-900 block">⭐ Moderar Reseñas</a>
                <a href="/Admin/ReportManagement" class="px-4 py-3 rounded-xl text-left text-[#c8c1b0] hover:bg-neutral-900 block">🚨 Reportes Formales</a>
                <a href="/Admin/UserManagement" class="px-4 py-3 rounded-xl text-left text-[#c8c1b0] hover:bg-neutral-900 block">👥 Control de Usuarios</a>
            </div>
        </div>
        <button onclick="localStorage.clear(); window.location.href='/Auth/Login';" class="w-full bg-neutral-900 py-3 rounded-xl text-xs font-bold text-neutral-400 hover:bg-red-600 hover:text-white">⚠️ CERRAR SESIÓN</button>
    </aside>

    <main class="flex-1 overflow-y-auto p-8">
        <h1 class="font-archivo text-2xl mb-2">Moderación de Reseñas</h1>
        <p class="text-xs text-neutral-500 mb-6 font-mono">Control de veracidad de calificaciones impugnadas por locales o motorizados.</p>
        <div id="reportedReviewsContainer" class="space-y-4 max-w-3xl"></div>
    </main>

    <script>
        const API_BASE = "https://localhost:7042";
        async function loadReportedReviews() {
        const res = await fetch(`${API_BASE}/api/Reviews/reported`);
        if (!res.ok) return;
        const reviews = await res.json();
        const container = document.getElementById('reportedReviewsContainer');
        container.innerHTML = '';
        if (reviews.length === 0) {
        container.innerHTML = `<p class="text-xs font-mono text-neutral-400 p-4 bg-white border border-black rounded-xl">Bandeja de reclamos limpia.</p>`;
        return;
        }
        reviews.forEach(r => {
        container.innerHTML += `
        <div class="bg-white border-2 border-[#14120F] rounded-2xl p-5 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
        <p class="text-sm font-medium bg-neutral-50 p-3 rounded-xl">"${r.comment || 'Sólo estrellas.'}"</p>
        <div class="bg-red-50 text-red-700 text-xs p-2 rounded-xl mt-2">🚨 Alerta: ${r.reportReason || 'Reclamada como falsa.'}</div>
        <div class="flex gap-2 mt-4">
        <button onclick="moderar(${r.id}, 'eliminar')" class="bg-[#FF4D2E] text-white px-4 py-1.5 rounded-xl text-xs font-bold border-2 border-black">🗑️ Eliminar</button>
        <button onclick="moderar(${r.id}, 'descartar')" class="bg-white text-neutral-700 px-4 py-1.5 rounded-xl text-xs font-bold border-2 border-black">✓ Mantener</button>
        </div>
        </div>`;
        });
        }
        async function moderar(id, acc) {
        const url = acc === 'eliminar' ? `${API_BASE}/api/Reviews/${id}` : `${API_BASE}/api/Reviews/${id}/dismiss`;
        const method = acc === 'eliminar' ? 'DELETE' : 'PUT';
        await fetch(url, { method });
        loadReportedReviews();
        }
        loadReportedReviews();
    </script>
</body>
</html>