@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <title>Bandeja de Incidentes — GoDelivery</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
        font-family: 'Inter', sans-serif;
        background-color: #FBF6EC;
        color: #14120F;
        }

        .font-archivo {
        font-family: 'Archivo Black', sans-serif;
        }
    </style>
</head>
<body class="h-screen flex overflow-hidden">

    <aside class="w-64 bg-[#14120F] text-[#FBF6EC] p-6 flex flex-col justify-between shrink-0">
        <div>
            <div class="font-mono text-sm tracking-wider mb-8 font-bold text-[#FF4D2E]">DELIVERY · ADMIN</div>
            <div class="flex flex-col gap-1 text-sm font-medium">
                <button onclick="showTab('dashboard')" class="tab-btn active px-4 py-3 rounded-xl text-left" data-tab="dashboard">📊 Dashboard Global</button>
                <button onclick="showTab('cuentas')" class="tab-btn px-4 py-3 rounded-xl text-left text-[#c8c1b0] hover:bg-neutral-900" data-tab="cuentas">👤 Contratar Personal</button>
                <a href="/Admin/CouponManagement" class="px-4 py-3 rounded-xl text-left text-[#c8c1b0] hover:bg-neutral-900 block">🏷️ Cupones</a>
                <a href="/Admin/ReviewModeration" class="px-4 py-3 rounded-xl text-left text-[#c8c1b0] hover:bg-neutral-900 block">⭐ Moderar Reseñas</a>
                <a href="/Admin/ReportManagement" class="px-4 py-3 rounded-xl text-left text-[#c8c1b0] hover:bg-neutral-900 block">🚨 Reportes Formales</a>
                <a href="/Admin/UserManagement" class="px-4 py-3 rounded-xl text-left text-[#c8c1b0] hover:bg-neutral-900 block">👥 Control de Usuarios</a>
            </div>
        </div>
        <button onclick="localStorage.clear(); window.location.href='/Auth/Login';" class="w-full bg-neutral-900 py-3 rounded-xl text-xs font-bold text-neutral-400 hover:bg-red-600 hover:text-white">⚠️ CERRAR SESIÓN</button>
    </aside>

    <main class="flex-1 overflow-y-auto p-8">
        <h1 class="font-archivo text-2xl mb-2">Bandeja de Incidentes Globales</h1>
        <p class="text-xs text-neutral-500 mb-6 font-mono">Resolución de quejas de la tabla Reports enviadas por clientes, locales o motorizados.</p>
        <div id="reportsListContainer" class="space-y-4 max-w-4xl"></div>
    </main>

    <script>
        const API_BASE = "https://localhost:7042";
        async function loadReports() {
        const res = await fetch(`${API_BASE}/api/Reports`);
        if (!res.ok) return;
        const reports = await res.json();
        const container = document.getElementById('reportsListContainer');
        container.innerHTML = '';
        if (reports.length === 0) {
        container.innerHTML = `<div class="bg-white border p-6 rounded-2xl font-mono text-center">✅ Sin incidentes pendientes.</div>`;
        return;
        }
        reports.forEach(r => {
        let denunciado = "Objeto no definido";
        if (r.restaurantId) denunciado = `🍽️ Restaurante: ${r.restaurant ? (r.restaurant.commercialName || r.restaurant.name) : 'ID ' + r.restaurantId}`;
        else if (r.deliveryId) denunciado = `🛵 Repartidor: ${r.delivery ? r.delivery.name : 'ID ' + r.deliveryId}`;
        else if (r.productId) denunciado = `🍔 Producto: ${r.product ? r.product.name : 'ID ' + r.productId}`;
        else if (r.clientId) denunciado = `👤 Cliente: ${r.client ? r.client.name : 'ID ' + r.clientId}`;


        container.innerHTML += `
        <div class="bg-white border-2 border-[#14120F] rounded-2xl p-5 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
        <div class="text-xs font-mono mb-2"><span class="bg-black text-white px-2 py-0.5 rounded">#REP-${r.id}</span></div>
        <p class="text-sm font-medium bg-red-50/50 p-3 rounded-xl border border-red-100">"${r.reason}"</p>
        <div class="text-xs mt-2 font-mono text-neutral-600">🎯 Acusado: ${denunciado}</div>
        <div class="flex justify-end mt-4"><button onclick="resolveIncident(${r.id})" class="border-2 border-black px-4 py-1.5 rounded-xl text-xs font-bold hover:bg-neutral-900 hover:text-white transition-colors">✓ Resolver Caso</button></div>
        </div>`;
        });
        }
        async function resolveIncident(id) {
        await fetch(`${API_BASE}/api/Reports/${id}/resolve`, { method: 'PUT' });
        loadReports();
        }
        loadReports();
    </script>
</body>
</html>