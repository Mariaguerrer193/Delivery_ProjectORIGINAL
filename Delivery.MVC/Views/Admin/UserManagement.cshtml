@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <title>Control de Usuarios — GoDelivery</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
        font-family: 'Inter', sans-serif;
        background-color: #FBF6EC;
        color: #14120F;
        }

        .font-archivo {
        font-family: 'Archivo Black', sans-serif;
        }
    </style>
</head>
<body class="h-screen flex overflow-hidden">

    <!-- NAV LATERAL UNIFICADA -->
    <aside class="w-64 bg-[#14120F] text-[#FBF6EC] p-6 flex flex-col justify-between shrink-0">
        <div>
            <div class="font-mono text-sm tracking-wider mb-8 font-bold text-[#FF4D2E]">DELIVERY · ADMIN</div>
            <div class="flex flex-col gap-1 text-sm font-medium">
                <button onclick="showTab('dashboard')" class="tab-btn active px-4 py-3 rounded-xl text-left" data-tab="dashboard">📊 Dashboard Global</button>
                <button onclick="showTab('cuentas')" class="tab-btn px-4 py-3 rounded-xl text-left text-[#c8c1b0] hover:bg-neutral-900" data-tab="cuentas">👤 Contratar Personal</button>
                <a href="/Admin/CouponManagement" class="px-4 py-3 rounded-xl text-left text-[#c8c1b0] hover:bg-neutral-900 block">🏷️ Cupones</a>
                <a href="/Admin/ReviewModeration" class="px-4 py-3 rounded-xl text-left text-[#c8c1b0] hover:bg-neutral-900 block">⭐ Moderar Reseñas</a>
                <a href="/Admin/ReportManagement" class="px-4 py-3 rounded-xl text-left text-[#c8c1b0] hover:bg-neutral-900 block">🚨 Reportes Formales</a>
                <a href="/Admin/UserManagement" class="px-4 py-3 rounded-xl text-left text-[#c8c1b0] hover:bg-neutral-900 block">👥 Control de Usuarios</a>
            </div>
        </div>
        <button onclick="localStorage.clear(); window.location.href='/Auth/Login';" class="w-full bg-neutral-900 py-3 rounded-xl text-xs font-bold text-neutral-400 hover:bg-red-600 hover:text-white">⚠️ CERRAR SESIÓN</button>
    </aside>

    <!-- CUERPO DE LA CONSOLA -->
    <main class="flex-1 overflow-y-auto p-8">
        <h1 class="font-archivo text-2xl mb-2">Control General de Cuentas</h1>
        <p class="text-xs text-neutral-500 mb-6 font-mono">Consola de seguridad central. Permite activar o suspender los accesos de Clientes, Locales y Repartidores protegiendo sus relaciones históricas.</p>

        <div class="grid grid-cols-1 xl:grid-cols-3 gap-6 max-w-7xl">

            <!-- COLUMNA CLIENTES -->
            <div>
                <h3 class="font-archivo text-xs uppercase tracking-wider text-emerald-600 mb-3">👤 Clientes</h3>
                <div id="clientsAdminList" class="space-y-3"><p class="text-xs font-mono text-neutral-400">Escaneando...</p></div>
            </div>

            <!-- COLUMNA RESTAURANTES -->
            <div>
                <h3 class="font-archivo text-xs uppercase tracking-wider text-amber-600 mb-3">🍳 Restaurantes</h3>
                <div id="restaurantsAdminList" class="space-y-3"><p class="text-xs font-mono text-neutral-400">Escaneando...</p></div>
            </div>

            <!-- COLUMNA REPARTIDORES -->
            <div>
                <h3 class="font-archivo text-xs uppercase tracking-wider text-indigo-600 mb-3">🛵 Repartidores</h3>
                <div id="deliveriesAdminList" class="space-y-3"><p class="text-xs font-mono text-neutral-400">Escaneando...</p></div>
            </div>

        </div>
    </main>

    <script>
        const API_BASE = "https://localhost:7042";

        async function loadAllUsers() {
        try {
        // 1. Obtener Clientes
        const resCli = await fetch(`${API_BASE}/api/Clients`);
        if (resCli.ok) {
        const clients = await resCli.json();
        const container = document.getElementById('clientsAdminList');
        container.innerHTML = clients.length === 0 ? '<p class="text-xs font-mono text-neutral-400">Sin registros.</p>' : '';
        clients.forEach(c => {
        container.innerHTML += createCardHtml(c.id, c.name, c.email, `Telf: ${c.phone}`, c.isActive, 'Clients');
        });
        }

        // 2. Obtener Restaurantes
        const resRest = await fetch(`${API_BASE}/api/Restaurants`);
        if (resRest.ok) {
        const restaurants = await resRest.json();
        const container = document.getElementById('restaurantsAdminList');
        container.innerHTML = restaurants.length === 0 ? '<p class="text-xs font-mono text-neutral-400">Sin registros.</p>' : '';
        restaurants.forEach(r => {
        container.innerHTML += createCardHtml(r.id, r.commercialName, r.email, r.category, r.isActive, 'Restaurants');
        });
        }

        // 3. Obtener Repartidores
        const resDeliv = await fetch(`${API_BASE}/api/Deliveries`);
        if (resDeliv.ok) {
        const deliveries = await resDeliv.json();
        const container = document.getElementById('deliveriesAdminList');
        container.innerHTML = deliveries.length === 0 ? '<p class="text-xs font-mono text-neutral-400">Sin registros.</p>' : '';
        deliveries.forEach(d => {
        container.innerHTML += createCardHtml(d.id, d.name, d.email, `Licencia: ${d.license || 'N/A'}`, d.isActive, 'Deliveries');
        });
        }
        } catch (err) { console.error("Error al cargar usuarios:", err); }
        }

        function createCardHtml(id, name, email, details, isActive, endpoint) {
        return `
        <div class="bg-white border-2 border-[#14120F] p-4 rounded-xl shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] flex flex-col justify-between gap-3">
        <div>
        <h4 class="text-xs font-bold text-neutral-800 truncate">${name}</h4>
        <p class="text-[10px] font-mono text-neutral-400 truncate">${email}</p>
        <p class="text-[10px] font-mono text-neutral-500 font-medium truncate">${details}</p>
        <span class="inline-block text-[9px] font-mono font-bold px-1.5 py-0.5 rounded border mt-2 ${isActive ? 'bg-emerald-50 text-emerald-700 border-emerald-300':'bg-red-50 text-red-700 border-red-300'}">
        ${isActive ? '● ACCESO PERMITIDO' : '⛔ SUSPENDIDO'}
        </span>
        </div>
        <button onclick="toggleUserStatus(${id}, ${isActive}, '${endpoint}')" class="w-full text-[10px] font-bold border-2 border-black py-1 rounded-xl transition-all ${isActive ? 'bg-white text-black hover:bg-neutral-100':'bg-neutral-900 text-white hover:bg-red-500'}">
        ${isActive ? '⛔ Suspender' : '⚡ Activar'}
        </button>
        </div>`;
        }

        async function toggleUserStatus(id, currentStatus, endpoint) {
        try {
        const getRes = await fetch(`${API_BASE}/api/${endpoint}/${id}`);
        if (getRes.ok) {
        const userObj = await getRes.json();
        userObj.isActive = !currentStatus; // Cambiamos el estado global heredado de Person

        const putRes = await fetch(`${API_BASE}/api/${endpoint}/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(userObj)
        });
        if (putRes.ok) {
        loadAllUsers();
        } else {
        alert("Error al actualizar el estado del usuario.");
        }
        }
        } catch (err) { console.error(err); }
        }

        loadAllUsers();
    </script>
</body>
</html>